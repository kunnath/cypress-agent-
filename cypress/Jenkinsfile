pipeline {
    agent any

    stages {
        stage('Install dependencies') {
            steps {
                // ensure we have node modules
                sh 'npm ci || npm install'
            }
        }

        // no Python/Playwright stages needed for Cypress

        stage('Run Cypress tests') {
            steps {
                // execute the headless run and tell the plugin where to put results
                sh '''
                    npx cypress run --env allure=true,allureResultsPath=cypress/results
                '''
            }
        }

        stage('Allure report') {
            steps {
                // generate the report from the folder Cypress has just populated
                sh '''
                    npx allure generate cypress/results --clean -o cypress/report
                '''
                // keep the generated HTML as a Jenkins artifact
                archiveArtifacts artifacts: 'cypress/report/**', allowEmptyArchive: true
            }
        }
    }

    post {
        always {
            // archive whatever else you want (screenshots, videos, etc.)
            archiveArtifacts artifacts: 'cypress/videos/**, cypress/screenshots/**', allowEmptyArchive: true

            // publish the Allure results for the Jenkins Allure plugin
            allure([
                results: [[path: 'cypress/results']],   // relative to workspace
                reportBuildPolicy: 'ALWAYS'             // optional
            ])
        }
    }
}