{
  "name": "cypress-code",
  "version": "1.0.0",
  "description": "A Cypress test project with Allure reporting",
  "scripts": {
    "cypress:open": "cypress open",
    "cypress:run": "cypress run --env allure=true",
    "allure:generate": "allure generate cypress/results --clean -o cypress/report",
    "allure:open": "allure open cypress/report",
    "test": "npm run cypress:run && npm run allure:generate"
  },
  "devDependencies": {
    "cypress": "^12.0.0",
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "cypress-multi-reporters": "^1.4.0",
    "mocha-junit-reporter": "^2.0.0",
    "allure-commandline": "^2.13.8"
  }
}