{
  "name": "cypress-code",
  "version": "1.0.0",
  "description": "A Cypress test project with Allure reporting",
  "scripts": {
    "cypress:open": "cypress open",
    "cypress:run": "$(command -v xvfb-run >/dev/null 2>&1 && echo 'xvfb-run -a' || echo '') cypress run --env allure=true,allureResultsPath=cypress/results",
    "allure:generate": "allure generate cypress/results --clean -o cypress/report",
    "allure:open": "allure open cypress/report",
    "test": "npm run cypress:run && npm run allure:generate && npm run allure:open"
  },
  "devDependencies": {
    "@deploysentinel/cypress-recorder": "^0.1.0",
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "allure-commandline": "^2.13.8",
    "cypress": "^12.0.0",
    "cypress-multi-reporters": "^1.4.0",
    "cypress-xpath": "^2.0.1",
    "mocha-junit-reporter": "^2.0.0",
    "nuxt": "^2.18.1",
    "vue": "^2.7.16"
  }
}
